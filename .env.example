# Coziyoo shared / ops environment sample
# App-specific runtime values live in:
# - apps/api/.env
# - apps/admin/.env
# - apps/mobile/.env

REPO_ROOT=/opt/coziyoo
DEPLOY_BRANCH=main
ADMIN_DOMAIN=admin.example.com
API_DOMAIN=api.example.com
CLOUDFLARE_API_KEY=mock_cloudflare_api_key
SUPABASE_PERSONAL_ACCESS_TOKEN=mock_supabase_pat
SUPABASE_HOST_URL=https://example.supabase.co
Incoming_Server=mail.example.com
Incoming_Port=993
Incoming_Username=info@example.com
Incoming_Connection=SSL/TLS
Incoming_Password=mock_incoming_password
Outgoing_Server=mail.example.com
Outgoing_Port=465
Outgoing_Username=info@example.com
Outgoing_Connection=SSL/TLS
Outgoing_Password=mock_outgoing_password
