# Coziyoo environment sample
# Policy:
# - .env.local => local development runtime file (not committed)
# - .env.example => sample template (committed)
# - .env => production/runtime file (not committed)

# Core app
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006,http://localhost:3001,https://agent.coziyoo.com
JSON_BODY_LIMIT=15mb

# Auth / security (required)
APP_JWT_SECRET=change_me_app_jwt_secret_minimum_32_chars
ADMIN_JWT_SECRET=change_me_admin_jwt_secret_minimum_32_chars
PAYMENT_WEBHOOK_SECRET=change_me_payment_webhook_secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
DOCS_ENABLED=true

# Database (required, Supabase)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL_MODE=no-verify

# Payments
PAYMENT_PROVIDER_NAME=mockpay
PAYMENT_CHECKOUT_BASE_URL=https://checkout.example.com/session

# LiveKit (remote)
LIVEKIT_URL=wss://livekit.yourdomain.com
LIVEKIT_API_KEY=change_me_livekit_api_key
LIVEKIT_API_SECRET=change_me_livekit_api_secret
LIVEKIT_TOKEN_TTL_SECONDS=3600
LIVEKIT_AGENT_IDENTITY=coziyoo-ai-agent

# AI server bridge
AI_SERVER_SHARED_SECRET=change_me_ai_server_shared_secret_min_16
AI_SERVER_URL=http://127.0.0.1:9000
AI_SERVER_LIVEKIT_JOIN_PATH=/livekit/agent-session
AI_SERVER_TIMEOUT_MS=10000

# Ollama / LLM
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_TIMEOUT_MS=30000
OLLAMA_SYSTEM_PROMPT=You are Coziyoo AI assistant. Be concise and helpful.

# STT
SPEECH_TO_TEXT_BASE_URL=http://host.docker.internal:8001
STT_BASE_URL=http://host.docker.internal:8001
SPEECH_TO_TEXT_TRANSCRIBE_PATH=/v1/audio/transcriptions
SPEECH_TO_TEXT_MODEL=whisper-1
SPEECH_TO_TEXT_API_KEY=change_me_stt_api_key
SPEECH_TO_TEXT_TIMEOUT_MS=60000
SPEECH_TO_TEXT_MAX_AUDIO_BYTES=8000000

# TTS
TTS_BASE_URL=http://host.docker.internal:8002
TTS_F5_BASE_URL=http://host.docker.internal:8002
TTS_XTTS_BASE_URL=http://host.docker.internal:8020
TTS_CHATTERBOX_BASE_URL=http://host.docker.internal:8030
TTS_F5_SYNTH_PATH=/api/tts
TTS_XTTS_SYNTH_PATH=/tts
TTS_CHATTERBOX_SYNTH_PATH=/tts
TTS_LANGUAGE_DEFAULT=tr
TTS_SPEAKER_ID=default
TTS_CHATTERBOX_VOICE_MODE=predefined
TTS_CHATTERBOX_PREDEFINED_VOICE_ID=
TTS_CHATTERBOX_REFERENCE_AUDIO_FILENAME=
TTS_CHATTERBOX_OUTPUT_FORMAT=wav
TTS_CHATTERBOX_SPLIT_TEXT=true
TTS_CHATTERBOX_CHUNK_SIZE=120
TTS_CHATTERBOX_TEMPERATURE=0.7
TTS_CHATTERBOX_EXAGGERATION=1.0
TTS_CHATTERBOX_CFG_WEIGHT=0.5
TTS_CHATTERBOX_SEED=42
TTS_CHATTERBOX_SPEED_FACTOR=1.0
TTS_TIMEOUT_MS=30000
TTS_API_KEY=change_me_tts_api_key
TTS_SPEAKER_WAV_PATH=
TTS_XTTS_SPEAKER_WAV_URL=http://localhost:8020/speaker.wav

# Tools / integrations
TOOLS_REGISTRY_URL=https://registry.caal.io/index.json
N8N_BASE_URL=http://host.docker.internal:5678
N8N_API_KEY=change_me_n8n_api_key

# Admin frontend runtime
VITE_API_BASE_URL=http://localhost:3000

# Voice agent runtime (python app)
AI_SERVER_HOST=0.0.0.0
AI_SERVER_PORT=9000
API_BASE_URL=http://api:3000
