# Copy this file to installation/config.env
# This is the INSTALLATION configuration (not application config)
# Application config is at root .env

# -----------------------------
# Global Installation Settings
# -----------------------------
INSTALL_PREREQS=true
INSTALL_POSTGRES=true
INSTALL_API=true
INSTALL_ADMIN=true
INSTALL_VOICE_AGENT=true

# Git Settings
GIT_UPDATE=true
DEPLOY_BRANCH=main
# Runs post-deploy DB data patch scripts during updates.
APPLY_POST_DEPLOY_DATA_PATCHES=true
# Demo mode only: reset DB on every update (drops all current data).
DEMO_DB_REBUILD_ON_UPDATE=false
# Demo mode recommended: reset DB only when schema-related files changed in deploy diff.
DEMO_DB_REBUILD_ON_SCHEMA_CHANGE=true
# If demo DB rebuild is enabled, reseed admin/sample data after API restart.
DEMO_DB_RESEED_ON_UPDATE=true
# Always ensure admin login credentials after update.
ADMIN_SYNC_ON_UPDATE=true
ADMIN_SYNC_EMAIL=admin@coziyoo.com
ADMIN_SYNC_PASSWORD=Admin12345

# Deployment Path
REPO_ROOT=/opt/coziyoo

# Nginx Proxy Manager Settings
NPM_INSTALL_DIR=/root/nginx-proxy-manager
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_UI_PORT=81

# -----------------------------
# App Paths (relative to REPO_ROOT)
# -----------------------------
API_DIR=apps/api
ADMIN_DIR=apps/admin
ADMIN_PUBLISH_DIR=/var/www/coziyoo-admin
ADMIN_PORT=8000
ADMIN_SERVICE_NAME=coziyoo-admin
VOICE_AGENT_DIR=apps/voice-agent
VOICE_AGENT_HOST=0.0.0.0
VOICE_AGENT_PORT=9000
VOICE_AGENT_API_SERVICE_NAME=coziyoo-voice-agent-api
VOICE_AGENT_WORKER_SERVICE_NAME=coziyoo-voice-agent-worker

# -----------------------------
# Service Names
# -----------------------------
API_SERVICE_NAME=coziyoo-api
API_RUN_USER=root
API_RUN_GROUP=root
API_PORT=3000
API_START_CMD="node dist/src/server.js"
# Run db-migrate.sh automatically during update_api_service.sh
RUN_DB_MIGRATIONS_ON_UPDATE=true

# -----------------------------
# Domains
# -----------------------------
ADMIN_DOMAIN=admin.coziyoo.com
API_DOMAIN=api.coziyoo.com

# Frontend API base URLs
ADMIN_API_BASE_URL=https://api.coziyoo.com

# -----------------------------
# PostgreSQL Bootstrap
# -----------------------------
PG_DB=coziyoo
PG_USER=coziyoo
PG_PASSWORD=CHANGE_ME_DB_PASSWORD_12345

# -----------------------------
# Data Seeding (First Install Only)
# -----------------------------
# Set to true to seed sample data during install
SEED_SAMPLE_DATA=true
# If true, installation continues even when sample seeding fails
INSTALL_ALLOW_SEED_FAILURE=false

# Admin user credentials (used for admin login and sample data seeding)
SEED_ADMIN_EMAIL=admin@coziyoo.com
SEED_ADMIN_PASSWORD=Admin12345
# If true, seed-data.sh updates existing admin password hash to SEED_ADMIN_PASSWORD
SEED_ADMIN_PASSWORD_SYNC_IF_EXISTS=true
