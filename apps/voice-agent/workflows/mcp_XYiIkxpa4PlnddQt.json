    {
      "id": "orders-status-stub",
      "name": "Orders Status (Stub)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 420],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return [{ json: { ...$json, ok: false, status: 501, data: null, error: { code: 'NOT_IMPLEMENTED', message: 'Order status lookup is not yet implemented.' } } }];"
      }
    },
    {
      "id": "health-check-code",
      "name": "Health Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 580],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return [{ json: { ...$json, ok: true, status: 200, data: { service: 'mcp-gateway', status: 'ok' }, error: null } }];"
      }
    },
    {
      "id": "default-error-code",
      "name": "Unsupported Action",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 740],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return [{ json: { ...$json, ok: false, status: 400, data: null, error: { code: 'UNSUPPORTED_ACTION', message: `Unsupported action: ${$json.action}` } } }];"
      }
    },
    {
      "id": "normalize-result",
      "name": "Normalize Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 420],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize HTTP responses from products API into standard MCP envelope\nconst base = $('Normalize MCP Input').item.json;\n\n// If this came from an HTTP node, $json has the raw API response body\n// If it already has ok/status fields (stub nodes), pass through\nif ('ok' in $json || $json.error) {\n  return [{ json: { ...base, ok: Boolean($json.ok), status: Number($json.status || 200), data: $json.data ?? null, error: $json.error ?? null } }];\n}\n\n// Normalize foods API response: { data: { foods: [...], total: N } }\nconst apiData = $json.data || $json;\nconst foods = Array.isArray(apiData.foods) ? apiData.foods : [];\nconst total = typeof apiData.total === 'number' ? apiData.total : foods.length;\n\nreturn [{ json: { ...base, ok: true, status: 200, data: { foods, total }, error: null } }];"
      }
    },
    {
      "id": "audit",
      "name": "Audit Envelope",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1620, 420],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const finishedAt = Date.now();\nconst base = $('Normalize MCP Input').item.json;\nconst durationMs = finishedAt - Number(base.startedAt || finishedAt);\nconst classification = $json.ok ? 'success' : ($json.status >= 500 ? 'upstream_error' : 'client_error');\nreturn [{ json: {\n  ok: Boolean($json.ok),\n  status: Number($json.status || 500),\n  data: $json.data ?? null,\n  error: $json.error ?? null,\n  durationMs,\n  traceId: base.traceId,\n  roomId: base.roomId,\n  deviceId: base.deviceId,\n  requestedByWorkflowId: base.requestedByWorkflowId,\n  classification,\n  source: 'mcp-gateway'\n}}];"
      }
    },
    {
      "id": "respond",
      "name": "Respond MCP",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1880, 420],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {}
      }
    }
  ],
