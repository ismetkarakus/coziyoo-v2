    {
      "id": "normalize",
      "name": "Normalize MCP Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 320],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $json.body ?? $json;\nconst startedAt = Date.now();\nreturn [{ json: {\n  traceId: body.traceId || `mcp-${Date.now()}`,\n  action: String(body.action || 'unknown'),\n  params: typeof body.params === 'object' && body.params !== null ? body.params : {},\n  roomId: body.roomId || null,\n  deviceId: body.deviceId || null,\n  requestedByWorkflowId: body.requestedByWorkflowId || null,\n  startedAt\n}}];"
      }
    },
    {
      "id": "dispatch-switch",
      "name": "Dispatch Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [800, 320],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "products.search",
                    "operator": {
